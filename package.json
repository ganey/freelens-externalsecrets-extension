{
    "name": "freelens-externalsecrets-extension",
    "version": "0.2.8",
    "publisher": "ganey",
    "description": "Freelens extension for External Secrets Operator",
    "main": "out/main/index.js",
    "renderer": "out/renderer/index.js",
    "files": [
        "out/**/*"
    ],
    "engines": {
        "node": ">= 22.0.0",
        "freelens": "^1.8.0"
    },
    "scripts": {
        "type:check": "tsc --noEmit -p tsconfig.json --composite false",
        "build": "npm run type:check && electron-vite build",
        "build:force": "electron-vite build",
        "pack:dev": "npm version prerelease --preid dev --no-git-tag-version && npm run build && npm pack",
        "test": "jest"
    },
    "dependencies": {
        "mobx": "6.13.7",
        "mobx-react": "7.6.0"
    },
    "devDependencies": {
        "@babel/plugin-proposal-decorators": "^7.29.0",
        "@freelensapp/extensions": "^1.8.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@types/jest": "^29.0.0",
        "@types/node": "~22.19.11",
        "@types/react": "^17.0.90",
        "@types/react-dom": "^17.0.0",
        "@vitejs/plugin-react": "^5.1.3",
        "electron-vite": "^5.0.0",
        "jest": "^29.0.0",
        "jest-environment-jsdom": "^29.0.0",
        "prettier": "^3.5.3",
        "react": "17.0.2",
        "react-dom": "17.0.2",
        "ts-jest": "^29.0.0",
        "typescript": "5.9.3",
        "vite": "^7.3.1",
        "vite-plugin-external": "^6.2.2",
        "vite-plugin-sass-dts": "^1.3.35",
        "sass": "^1.97.3"
    }
}
